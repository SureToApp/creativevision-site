{
  "version": 2,
  "builds": [
    { "src": "*.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/privacy", "dest": "/privacy.html" },
    { "src": "/android", "dest": "/android.html" },
    { "src": "/partner/(.*)", "dest": "/partner.html" },
    { "src": "/support", "dest": "/support.html" },
    { "src": "/", "dest": "/index.html" }
  ]
}
